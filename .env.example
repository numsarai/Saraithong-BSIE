# === SECURITY (REQUIRED for production) ===
BSIE_JWT_SECRET=CHANGE-ME-use-python-c-import-secrets-print(secrets.token_hex(32))
BSIE_AUTH_REQUIRED=true
BSIE_ADMIN_INITIAL_PASSWORD=CHANGE-ME-set-strong-password

PORT=8757
BSIE_ENABLE_AUTO_BACKUP=1
BSIE_BACKUP_INTERVAL_HOURS=24
BSIE_AUTO_BACKUP_FORMAT=json
BSIE_BACKUP_POLL_SECONDS=60
BSIE_ENABLE_NEO4J_EXPORT=0
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me
NEO4J_DATABASE=neo4j
BSIE_NEO4J_BATCH_SIZE=250
BSIE_NEO4J_SYNC_FINDINGS=1
BSIE_ENABLE_LLM_CLASSIFICATION=0
LLM_API_KEY=
LLM_MODEL_NAME=gpt-4o-mini
BSIE_LLM_MIN_CONFIDENCE=0.85
BSIE_LLM_MAX_TRANSACTIONS=250
BSIE_LLM_ALLOW_NAME_OVERRIDE=1
BSIE_LLM_ALLOW_TYPE_OVERRIDE=1
BSIE_LLM_REVIEW_ON_DIVERGENCE=1

# === LOCAL OLLAMA (optional, self-hosted only) ===
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TEXT_MODEL=qwen2.5:14b
OLLAMA_VISION_MODEL=qwen2.5vl:7b
OLLAMA_FAST_MODEL=gemma4:e4b
OLLAMA_MAPPING_MODEL=qwen2.5:14b
OLLAMA_TIMEOUT=120
