/* ===================================================================
   BSIE – Premium Dark Dashboard CSS
   =================================================================== */

/* ── Tokens ──────────────────────────────────────────────────────── */
:root {
  --bg-base:      #0a0d14;
  --bg-panel:     #0f1420;
  --bg-panel-2:   #141928;
  --bg-hover:     #1a2036;
  --border:       rgba(99, 130, 255, 0.12);
  --border-glow:  rgba(99, 130, 255, 0.35);

  --accent:       #6382ff;
  --accent-dim:   #3a4fa8;
  --accent-glow:  rgba(99, 130, 255, 0.2);
  --teal:         #2dd4bf;
  --green:        #22c55e;
  --red:          #f87171;
  --amber:        #fbbf24;
  --purple:       #a78bfa;

  --text-primary:   #e8edff;
  --text-secondary: #7a8aad;
  --text-muted:     #3d4d6a;

  --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  --font-mono: 'JetBrains Mono', 'Fira Code', monospace;

  --radius-sm: 6px;
  --radius:    10px;
  --radius-lg: 16px;

  --shadow-panel: 0 4px 32px rgba(0,0,0,0.45);
  --shadow-glow:  0 0 24px rgba(99,130,255,0.15);
  --transition: 0.18s ease;
}

/* ── Reset ───────────────────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }

body {
  font-family: var(--font-sans);
  background: var(--bg-base);
  color: var(--text-primary);
  min-height: 100vh;
  font-size: 14px;
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

/* Grid background */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  background-image:
    linear-gradient(rgba(99,130,255,0.025) 1px, transparent 1px),
    linear-gradient(90deg, rgba(99,130,255,0.025) 1px, transparent 1px);
  background-size: 40px 40px;
  pointer-events: none;
  z-index: 0;
}

/* ── Header ──────────────────────────────────────────────────────── */
.header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(10,13,20,0.88);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--border);
}
.header-inner {
  max-width: 1280px;
  margin: 0 auto;
  padding: 14px 28px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.logo { display: flex; align-items: center; gap: 14px; }
.logo-icon {
  font-size: 28px;
  color: var(--accent);
  filter: drop-shadow(0 0 8px var(--accent));
  animation: pulse-glow 3s ease-in-out infinite;
}
@keyframes pulse-glow {
  0%,100% { filter: drop-shadow(0 0 6px var(--accent)); }
  50%      { filter: drop-shadow(0 0 16px var(--accent)); }
}
.logo-title   { font-size: 18px; font-weight: 700; letter-spacing: 1px; color: var(--text-primary); }
.logo-sub     { font-size: 11px; color: var(--text-secondary); letter-spacing: 0.05em; }

.header-badges { display: flex; gap: 8px; }
.badge {
  padding: 4px 10px;
  border-radius: 20px;
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.02em;
}
.badge-forensic { background: rgba(45,212,191,0.1); color: var(--teal); border: 1px solid rgba(45,212,191,0.25); }
.badge-version  { background: var(--accent-glow); color: var(--accent); border: 1px solid var(--border-glow); }

/* ── Main ────────────────────────────────────────────────────────── */
.main {
  position: relative;
  z-index: 1;
  max-width: 1280px;
  margin: 0 auto;
  padding: 32px 28px 80px;
  display: flex;
  flex-direction: column;
  gap: 24px;
}

/* ── Panel ───────────────────────────────────────────────────────── */
.panel {
  background: var(--bg-panel);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 28px;
  box-shadow: var(--shadow-panel);
  transition: box-shadow var(--transition);
}
.panel:hover { box-shadow: var(--shadow-panel), var(--shadow-glow); }

.panel-title {
  font-size: 15px;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20px;
  display: flex;
  align-items: center;
  gap: 10px;
}
.panel-icon { font-size: 18px; }

/* ── Drop Zone ───────────────────────────────────────────────────── */
.drop-zone {
  border: 2px dashed var(--border-glow);
  border-radius: var(--radius);
  padding: 40px 20px;
  text-align: center;
  cursor: pointer;
  transition: all var(--transition);
  margin-bottom: 24px;
  position: relative;
  overflow: hidden;
}
.drop-zone::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at 50% 0%, var(--accent-glow) 0%, transparent 70%);
  opacity: 0;
  transition: opacity var(--transition);
}
.drop-zone:hover::before, .drop-zone.drag-over::before { opacity: 1; }
.drop-zone:hover {
  border-color: var(--accent);
  background: rgba(99,130,255,0.04);
}
.drop-zone.drag-over {
  border-color: var(--teal);
  background: rgba(45,212,191,0.06);
  transform: scale(1.005);
}
.drop-icon { font-size: 40px; margin-bottom: 12px; }
.drop-text { color: var(--text-primary); font-size: 15px; font-weight: 500; }
.drop-hint { color: var(--text-secondary); font-size: 12px; margin-top: 6px; }
.link-text  { color: var(--accent); text-decoration: underline; cursor: pointer; }
.file-chosen {
  margin-top: 14px;
  padding: 10px 16px;
  background: rgba(34,197,94,0.1);
  border: 1px solid rgba(34,197,94,0.25);
  border-radius: var(--radius-sm);
  color: var(--green);
  font-size: 13px;
  font-family: var(--font-mono);
}

/* ── Form ────────────────────────────────────────────────────────── */
.form-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  margin-bottom: 24px;
}
.form-group { display: flex; flex-direction: column; gap: 6px; }
.form-group--full { grid-column: 1 / -1; }

label {
  font-size: 12px;
  font-weight: 600;
  color: var(--text-secondary);
  text-transform: uppercase;
  letter-spacing: 0.06em;
}
.optional { font-weight: 400; opacity: 0.6; text-transform: none; font-size: 11px; }
.field-hint { font-size: 11px; color: var(--text-muted); }

input[type="text"],
input[type="number"],
select {
  background: var(--bg-base);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  color: var(--text-primary);
  padding: 10px 14px;
  font-family: var(--font-sans);
  font-size: 14px;
  outline: none;
  transition: border-color var(--transition);
}
select option { background: var(--bg-panel-2); }
input:focus, select:focus { border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-glow); }

/* ── Buttons ─────────────────────────────────────────────────────── */
.btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 12px 28px;
  border: none;
  border-radius: var(--radius-sm);
  font-family: var(--font-sans);
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  transition: all var(--transition);
  letter-spacing: 0.02em;
}
.btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none !important; }
.btn-primary {
  background: linear-gradient(135deg, var(--accent) 0%, #4a60e0 100%);
  color: #fff;
  box-shadow: 0 4px 16px var(--accent-glow);
}
.btn-primary:not(:disabled):hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px var(--accent-glow);
}
.btn-secondary {
  background: var(--bg-panel-2);
  border: 1px solid var(--border);
  color: var(--text-primary);
}
.btn-secondary:hover { border-color: var(--accent); color: var(--accent); }
.btn-dl {
  padding: 7px 14px;
  font-size: 12px;
  font-weight: 500;
  background: rgba(99,130,255,0.1);
  border: 1px solid rgba(99,130,255,0.25);
  color: var(--accent);
  border-radius: var(--radius-sm);
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 5px;
  transition: all var(--transition);
}
.btn-dl:hover { background: var(--accent); color: #fff; }
.btn-icon { font-size: 16px; }

/* ── Spinner ─────────────────────────────────────────────────────── */
.spinner {
  display: inline-block;
  width: 16px;
  height: 16px;
  border: 2px solid var(--border);
  border-top-color: var(--accent);
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
  margin-left: 8px;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* ── Log Console ──────────────────────────────────────────────────── */
.panel-progress { border-color: rgba(99,130,255,0.2); }
.log-container {
  background: var(--bg-base);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  height: 220px;
  overflow-y: auto;
  padding: 0;
}
.log-output {
  font-family: var(--font-mono);
  font-size: 12px;
  line-height: 1.7;
  color: var(--text-secondary);
  padding: 12px 16px;
  white-space: pre-wrap;
  word-break: break-word;
}
.log-output .log-info    { color: var(--accent); }
.log-output .log-error   { color: var(--red); }
.log-output .log-success { color: var(--green); }

/* ── Stat Cards ───────────────────────────────────────────────────── */
.stat-cards {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 16px;
}
.stat-card {
  background: var(--bg-panel);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 20px;
  position: relative;
  overflow: hidden;
  transition: transform var(--transition), box-shadow var(--transition);
}
.stat-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-glow); }
.stat-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: var(--card-color, var(--accent));
}
.stat-icon  { font-size: 22px; margin-bottom: 10px; }
.stat-value { font-size: 26px; font-weight: 700; color: var(--card-color, var(--accent)); margin-bottom: 4px; font-family: var(--font-mono); }
.stat-label { font-size: 11px; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.07em; }

/* ── Tabs ─────────────────────────────────────────────────────────── */
.tabs-bar {
  display: flex;
  gap: 4px;
  background: var(--bg-panel);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 6px;
}
.tab-btn {
  flex: 1;
  padding: 10px 16px;
  border: none;
  background: none;
  border-radius: var(--radius-sm);
  color: var(--text-secondary);
  font-family: var(--font-sans);
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  transition: all var(--transition);
}
.tab-btn.active {
  background: var(--accent-glow);
  color: var(--accent);
  border: 1px solid var(--border-glow);
}
.tab-btn:not(.active):hover { background: var(--bg-hover); color: var(--text-primary); }

/* ── Panel Toolbar ──────────────────────────────────────────────────── */
.panel-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16px;
  flex-wrap: wrap;
  gap: 12px;
}
.panel-toolbar .panel-title { margin-bottom: 0; }
.toolbar-right { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
.search-box {
  padding: 7px 12px;
  font-size: 13px;
  width: 220px;
}
.download-group { display: flex; gap: 8px; flex-wrap: wrap; }

/* ── Data Table ───────────────────────────────────────────────────── */
.table-wrap {
  overflow-x: auto;
  border-radius: var(--radius-sm);
  border: 1px solid var(--border);
}
.data-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 12.5px;
}
.data-table thead th {
  background: var(--bg-panel-2);
  color: var(--text-secondary);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  font-size: 11px;
  padding: 10px 12px;
  text-align: left;
  white-space: nowrap;
  border-bottom: 1px solid var(--border);
  cursor: pointer;
  user-select: none;
}
.data-table thead th:hover { color: var(--text-primary); }
.data-table tbody tr {
  border-bottom: 1px solid rgba(99,130,255,0.06);
  transition: background var(--transition);
}
.data-table tbody tr:hover { background: var(--bg-hover); }
.data-table tbody td {
  padding: 9px 12px;
  color: var(--text-primary);
  max-width: 220px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.data-table tbody td.mono { font-family: var(--font-mono); font-size: 12px; }

/* Type badges in tables */
.type-badge {
  display: inline-block;
  padding: 2px 8px;
  border-radius: 12px;
  font-size: 11px;
  font-weight: 600;
  white-space: nowrap;
}
.type-IN_TRANSFER   { background: rgba(34,197,94,0.12);  color: var(--green);  border: 1px solid rgba(34,197,94,0.25); }
.type-OUT_TRANSFER  { background: rgba(99,130,255,0.12); color: var(--accent); border: 1px solid rgba(99,130,255,0.25); }
.type-DEPOSIT       { background: rgba(45,212,191,0.12); color: var(--teal);   border: 1px solid rgba(45,212,191,0.25); }
.type-WITHDRAW      { background: rgba(248,113,113,0.12);color: var(--red);    border: 1px solid rgba(248,113,113,0.25); }
.type-IN_UNKNOWN    { background: rgba(251,191,36,0.10); color: var(--amber);  border: 1px solid rgba(251,191,36,0.2); }
.type-OUT_UNKNOWN   { background: rgba(251,191,36,0.10); color: var(--amber);  border: 1px solid rgba(251,191,36,0.2); }
.type-ACCOUNT       { background: rgba(34,197,94,0.12);  color: var(--green);  border: 1px solid rgba(34,197,94,0.25); }
.type-PARTIAL_ACCOUNT { background:rgba(251,191,36,0.10); color: var(--amber); border: 1px solid rgba(251,191,36,0.2); }
.type-NAME          { background: rgba(167,139,250,0.12);color: var(--purple); border: 1px solid rgba(167,139,250,0.25); }
.type-UNKNOWN       { background: rgba(100,116,139,0.15);color: #64748b;       border: 1px solid rgba(100,116,139,0.25); }

/* IN / OUT direction */
.dir-IN  { color: var(--green);  font-weight: 600; }
.dir-OUT { color: var(--red);    font-weight: 600; }

/* Amount color */
.amount-pos { color: var(--green); font-family: var(--font-mono); font-weight: 600; }
.amount-neg { color: var(--red);   font-family: var(--font-mono); font-weight: 600; }

/* ── Toast ────────────────────────────────────────────────────────── */
.toast {
  position: fixed;
  bottom: 28px;
  left: 50%;
  transform: translateX(-50%) translateY(0);
  background: var(--bg-panel-2);
  border: 1px solid var(--border-glow);
  color: var(--text-primary);
  padding: 12px 24px;
  border-radius: 40px;
  font-size: 13px;
  box-shadow: var(--shadow-panel);
  z-index: 999;
  transition: opacity 0.3s, transform 0.3s;
}
.toast.hidden { opacity: 0; pointer-events: none; transform: translateX(-50%) translateY(20px); }

/* ── Utilities ────────────────────────────────────────────────────── */
.hidden      { display: none !important; }
.center-wrap { display: flex; justify-content: center; }

/* ── Responsive ───────────────────────────────────────────────────── */
@media (max-width: 700px) {
  .form-grid { grid-template-columns: 1fr; }
  .panel { padding: 20px; }
  .main  { padding: 20px 16px 60px; }
  .header-badges { display: none; }
  .stat-cards { grid-template-columns: 1fr 1fr; }
}
